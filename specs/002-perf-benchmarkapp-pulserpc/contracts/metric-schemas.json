{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PulseRPC Benchmark Metrics Schemas",
  "description": "JSON Schema definitions for benchmark performance metrics",
  "definitions": {
    "PerformanceMetrics": {
      "type": "object",
      "description": "Complete performance metrics snapshot",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Metric sample timestamp (UTC)"
        },
        "elapsedTime": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}(\\.\\d+)?$",
          "description": "Time since test start (HH:MM:SS.fff)"
        },
        "latency": { "$ref": "#/definitions/LatencyMetrics" },
        "throughput": { "$ref": "#/definitions/ThroughputMetrics" },
        "connections": { "$ref": "#/definitions/ConnectionMetrics" },
        "success": { "$ref": "#/definitions/SuccessMetrics" },
        "resources": { "$ref": "#/definitions/ResourceMetrics" },
        "network": { "$ref": "#/definitions/NetworkMetrics" }
      },
      "required": ["timestamp", "elapsedTime", "latency", "throughput", "success"]
    },

    "LatencyMetrics": {
      "type": "object",
      "description": "Latency percentile statistics in milliseconds",
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0,
          "description": "Minimum latency (ms)"
        },
        "max": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum latency (ms)"
        },
        "mean": {
          "type": "number",
          "minimum": 0,
          "description": "Average latency (ms)"
        },
        "median": {
          "type": "number",
          "minimum": 0,
          "description": "50th percentile (ms)"
        },
        "p50": {
          "type": "number",
          "minimum": 0,
          "description": "50th percentile (ms)"
        },
        "p75": {
          "type": "number",
          "minimum": 0,
          "description": "75th percentile (ms)"
        },
        "p90": {
          "type": "number",
          "minimum": 0,
          "description": "90th percentile (ms)"
        },
        "p95": {
          "type": "number",
          "minimum": 0,
          "description": "95th percentile (ms)"
        },
        "p99": {
          "type": "number",
          "minimum": 0,
          "description": "99th percentile (ms)"
        },
        "p999": {
          "type": "number",
          "minimum": 0,
          "description": "99.9th percentile (ms)"
        },
        "stdDev": {
          "type": "number",
          "minimum": 0,
          "description": "Standard deviation (ms)"
        }
      },
      "required": ["min", "max", "mean", "p50", "p95", "p99"]
    },

    "ThroughputMetrics": {
      "type": "object",
      "description": "Throughput rate statistics",
      "properties": {
        "messagesPerSecond": {
          "type": "number",
          "minimum": 0,
          "description": "Messages per second"
        },
        "bytesSentPerSecond": {
          "type": "number",
          "minimum": 0,
          "description": "Bytes sent per second"
        },
        "bytesReceivedPerSecond": {
          "type": "number",
          "minimum": 0,
          "description": "Bytes received per second"
        },
        "totalMessagesSent": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative messages sent"
        },
        "totalMessagesReceived": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative messages received"
        },
        "totalBytesSent": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative bytes sent"
        },
        "totalBytesReceived": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative bytes received"
        }
      },
      "required": ["messagesPerSecond", "bytesSentPerSecond", "bytesReceivedPerSecond"]
    },

    "ConnectionMetrics": {
      "type": "object",
      "description": "Connection state statistics",
      "properties": {
        "activeConnections": {
          "type": "integer",
          "minimum": 0,
          "description": "Currently active connections"
        },
        "totalConnectionsEstablished": {
          "type": "integer",
          "minimum": 0,
          "description": "Total connections established"
        },
        "totalConnectionsFailed": {
          "type": "integer",
          "minimum": 0,
          "description": "Total failed connection attempts"
        },
        "connectionEstablishmentTime": {
          "type": "number",
          "minimum": 0,
          "description": "Average connection establishment time (ms)"
        },
        "reconnectionCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of reconnections"
        }
      },
      "required": ["activeConnections"]
    },

    "SuccessMetrics": {
      "type": "object",
      "description": "Success and failure rate statistics",
      "properties": {
        "totalRequests": {
          "type": "integer",
          "minimum": 0,
          "description": "Total requests sent"
        },
        "successfulRequests": {
          "type": "integer",
          "minimum": 0,
          "description": "Successful responses received"
        },
        "failedRequests": {
          "type": "integer",
          "minimum": 0,
          "description": "Failed requests"
        },
        "timeoutCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Timeout errors"
        },
        "successRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Success rate percentage"
        },
        "errorRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Error rate percentage"
        }
      },
      "required": ["totalRequests", "successfulRequests", "failedRequests", "successRate"]
    },

    "ResourceMetrics": {
      "type": "object",
      "description": "System resource utilization",
      "properties": {
        "cpuUsagePercent": {
          "type": "number",
          "minimum": 0,
          "description": "CPU usage percentage (can exceed 100 on multi-core)"
        },
        "memoryUsageMB": {
          "type": "number",
          "minimum": 0,
          "description": "Working set memory in MB"
        },
        "threadCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Active thread count"
        },
        "gcGen0Collections": {
          "type": "integer",
          "minimum": 0,
          "description": "Generation 0 garbage collections"
        },
        "gcGen1Collections": {
          "type": "integer",
          "minimum": 0,
          "description": "Generation 1 garbage collections"
        },
        "gcGen2Collections": {
          "type": "integer",
          "minimum": 0,
          "description": "Generation 2 garbage collections"
        }
      },
      "required": ["cpuUsagePercent", "memoryUsageMB"]
    },

    "NetworkMetrics": {
      "type": "object",
      "description": "Network interface statistics",
      "properties": {
        "bytesSent": {
          "type": "integer",
          "minimum": 0,
          "description": "Total bytes sent"
        },
        "bytesReceived": {
          "type": "integer",
          "minimum": 0,
          "description": "Total bytes received"
        },
        "packetsSent": {
          "type": "integer",
          "minimum": 0,
          "description": "Packets sent (if available)"
        },
        "packetsReceived": {
          "type": "integer",
          "minimum": 0,
          "description": "Packets received (if available)"
        },
        "packetLoss": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Packet loss percentage (if detectable)"
        }
      }
    },

    "BenchmarkReport": {
      "type": "object",
      "description": "Complete benchmark report",
      "properties": {
        "reportId": {
          "type": "string",
          "format": "uuid",
          "description": "Unique report identifier"
        },
        "scenario": { "$ref": "#/definitions/BenchmarkScenario" },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "Test start time (UTC)"
        },
        "endTime": {
          "type": "string",
          "format": "date-time",
          "description": "Test end time (UTC)"
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}(\\.\\d+)?$",
          "description": "Total test duration"
        },
        "aggregatedMetrics": { "$ref": "#/definitions/PerformanceMetrics" },
        "timeSeriesMetrics": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceMetrics" },
          "description": "Time-series metric samples"
        },
        "environment": { "$ref": "#/definitions/EnvironmentInfo" },
        "baselineComparison": { "$ref": "#/definitions/BaselineComparison" },
        "thresholdResults": {
          "type": "array",
          "items": { "$ref": "#/definitions/ThresholdResult" }
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/definitions/ErrorSummary" }
        },
        "status": {
          "type": "string",
          "enum": ["Pass", "Fail", "Warning"],
          "description": "Overall test status"
        }
      },
      "required": ["reportId", "scenario", "startTime", "endTime", "aggregatedMetrics", "environment", "status"]
    },

    "BenchmarkScenario": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["PingPong", "Throughput", "ConcurrentConnection", "Streaming", "Stability"]
        },
        "name": { "type": "string", "maxLength": 100 },
        "description": { "type": "string" },
        "configuration": { "$ref": "#/definitions/TestConfiguration" }
      },
      "required": ["type", "name", "configuration"]
    },

    "TestConfiguration": {
      "type": "object",
      "properties": {
        "serverAddress": {
          "type": "string",
          "pattern": "^[^:]+:\\d+$",
          "description": "Server address (host:port)"
        },
        "transportProtocol": {
          "type": "string",
          "enum": ["TCP", "KCP"]
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}(\\.\\d+)?$",
          "description": "Test duration (HH:MM:SS)"
        },
        "iterationCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000000,
          "description": "Fixed iteration count (alternative to duration)"
        },
        "connectionCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "requestRate": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "description": "Requests per second per connection"
        },
        "messageSize": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10485760,
          "description": "Message size in bytes"
        }
      },
      "required": ["serverAddress", "transportProtocol", "connectionCount", "requestRate", "messageSize"],
      "oneOf": [
        { "required": ["duration"] },
        { "required": ["iterationCount"] }
      ]
    },

    "EnvironmentInfo": {
      "type": "object",
      "properties": {
        "operatingSystem": { "type": "string" },
        "processorName": { "type": "string" },
        "processorCount": { "type": "integer", "minimum": 1 },
        "totalMemoryMB": { "type": "number", "minimum": 0 },
        "dotNetVersion": { "type": "string" },
        "architecture": {
          "type": "string",
          "enum": ["x86", "x64", "ARM", "ARM64"]
        },
        "machineName": { "type": "string" }
      },
      "required": ["operatingSystem", "processorName", "processorCount", "totalMemoryMB", "dotNetVersion", "architecture"]
    },

    "BaselineComparison": {
      "type": "object",
      "properties": {
        "baselineName": { "type": "string" },
        "latencyDelta": {
          "type": "object",
          "properties": {
            "p95DeltaPercent": { "type": "number" },
            "p99DeltaPercent": { "type": "number" }
          }
        },
        "throughputDelta": {
          "type": "object",
          "properties": {
            "messagesPerSecondDeltaPercent": { "type": "number" }
          }
        },
        "overallRegression": { "type": "boolean" },
        "regressionDetails": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "ThresholdResult": {
      "type": "object",
      "properties": {
        "metricName": { "type": "string" },
        "operator": {
          "type": "string",
          "enum": ["LessThan", "LessThanOrEqual", "GreaterThan", "GreaterThanOrEqual", "Between"]
        },
        "targetValue": { "type": "number" },
        "actualValue": { "type": "number" },
        "passed": { "type": "boolean" },
        "message": { "type": "string" }
      },
      "required": ["metricName", "operator", "targetValue", "actualValue", "passed", "message"]
    },

    "ErrorSummary": {
      "type": "object",
      "properties": {
        "errorType": { "type": "string" },
        "count": { "type": "integer", "minimum": 1 },
        "firstOccurrence": { "type": "string", "format": "date-time" },
        "lastOccurrence": { "type": "string", "format": "date-time" },
        "sampleMessages": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        }
      },
      "required": ["errorType", "count", "firstOccurrence", "lastOccurrence"]
    }
  }
}
