{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PulseRPC Benchmark Server Configuration Template",
  "description": "服务端配置模板，包含所有可配置选项及说明",

  "port": 8080,
  "metricsPort": 9090,
  "maxConnections": 1000,
  "enableCompression": true,
  "keepAliveIntervalSeconds": 30,
  "connectionTimeoutSeconds": 120,
  "enableVerboseLogging": false,
  "workerThreads": 0,
  "bufferSize": 65536,
  "enablePerformanceCounters": true,
  "healthCheckIntervalSeconds": 10,

  "_comments": {
    "port": "服务器监听端口，范围：1-65535",
    "metricsPort": "指标监控端口，不能与服务端口相同",
    "maxConnections": "最大并发连接数",
    "enableCompression": "启用数据压缩",
    "keepAliveIntervalSeconds": "TCP保活间隔（秒）",
    "connectionTimeoutSeconds": "连接超时时间（秒）",
    "enableVerboseLogging": "启用详细日志输出",
    "workerThreads": "工作线程数，0表示自动检测",
    "bufferSize": "网络缓冲区大小（字节）",
    "enablePerformanceCounters": "启用性能计数器",
    "healthCheckIntervalSeconds": "健康检查间隔（秒）"
  },

  "environments": {
    "development": {
      "port": 8080,
      "metricsPort": 9090,
      "maxConnections": 100,
      "enableCompression": false,
      "enableVerboseLogging": true,
      "healthCheckIntervalSeconds": 5
    },

    "testing": {
      "port": 8081,
      "metricsPort": 9091,
      "maxConnections": 500,
      "enableCompression": true,
      "enableVerboseLogging": true,
      "healthCheckIntervalSeconds": 5
    },

    "production": {
      "port": 8080,
      "metricsPort": 9090,
      "maxConnections": 10000,
      "enableCompression": true,
      "enableVerboseLogging": false,
      "workerThreads": 16,
      "bufferSize": 131072
    }
  }
}
