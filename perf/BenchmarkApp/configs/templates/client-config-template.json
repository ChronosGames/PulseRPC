{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PulseRPC Benchmark Client Configuration Template",
  "description": "客户端配置模板，包含所有可配置选项及说明",

  "serverAddress": "localhost:8080",
  "defaultScenario": "ping-pong",
  "connectionTimeoutMs": 30000,
  "requestTimeoutMs": 10000,
  "defaultConnections": 10,
  "defaultRequestRate": 100,
  "defaultDurationSeconds": 60,
  "enableRetry": true,
  "maxRetryAttempts": 3,
  "retryIntervalMs": 1000,

  "_comments": {
    "serverAddress": "目标服务器地址，格式：host:port",
    "defaultScenario": "默认测试场景名称",
    "connectionTimeoutMs": "连接超时时间（毫秒）",
    "requestTimeoutMs": "请求超时时间（毫秒）",
    "defaultConnections": "默认并发连接数",
    "defaultRequestRate": "默认请求速率（QPS）",
    "defaultDurationSeconds": "默认测试持续时间（秒）",
    "enableRetry": "启用重试机制",
    "maxRetryAttempts": "最大重试次数",
    "retryIntervalMs": "重试间隔（毫秒）"
  },

  "scenarios": {
    "ping-pong": {
      "name": "ping-pong",
      "description": "简单的Ping-Pong延迟测试",
      "recommendedConnections": 10,
      "recommendedRate": 100,
      "recommendedDuration": 60
    },

    "echo-latency": {
      "name": "echo-latency",
      "description": "Echo回显延迟测试",
      "recommendedConnections": 20,
      "recommendedRate": 200,
      "recommendedDuration": 120
    },

    "throughput": {
      "name": "throughput",
      "description": "吞吐量压力测试",
      "recommendedConnections": 50,
      "recommendedRate": 1000,
      "recommendedDuration": 300
    },

    "latency-analysis": {
      "name": "latency-analysis",
      "description": "高级延迟分析测试",
      "recommendedConnections": 30,
      "recommendedRate": 500,
      "recommendedDuration": 180
    }
  },

  "profiles": {
    "light": {
      "defaultConnections": 5,
      "defaultRequestRate": 50,
      "defaultDurationSeconds": 30
    },

    "medium": {
      "defaultConnections": 20,
      "defaultRequestRate": 200,
      "defaultDurationSeconds": 120
    },

    "heavy": {
      "defaultConnections": 100,
      "defaultRequestRate": 1000,
      "defaultDurationSeconds": 300
    },

    "stress": {
      "defaultConnections": 500,
      "defaultRequestRate": 5000,
      "defaultDurationSeconds": 600
    }
  }
}
