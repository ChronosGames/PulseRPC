{
  "BenchmarkConfiguration": {
    "Host": "localhost",
    "Port": 12345,
    "TransportType": "tcp",
    "ConcurrentConnections": 1,
    "DurationSeconds": 30,
    "WarmupSeconds": 5,
    "MessageSizeBytes": 1024,
    "RequestIntervalMs": 0,
    "EnableVerboseLogging": false,
    "CollectResourceMetrics": true,
    "CustomProperties": {
      "TestEnvironment": "Development",
      "TestPurpose": "Performance Baseline"
    }
  },
  "Scenarios": [
    {
      "Name": "PingPong",
      "Enabled": true,
      "Configurations": [
        {
          "Name": "Small Messages",
          "MessageSizeBytes": 64,
          "DurationSeconds": 30,
          "Description": "测试小消息的延迟性能"
        },
        {
          "Name": "Medium Messages",
          "MessageSizeBytes": 1024,
          "DurationSeconds": 60,
          "Description": "测试中等消息的延迟性能"
        },
        {
          "Name": "Large Messages",
          "MessageSizeBytes": 8192,
          "DurationSeconds": 90,
          "Description": "测试大消息的延迟性能"
        }
      ]
    }
  ],
  "TransportOptions": {
    "Tcp": {
      "ConnectionTimeoutMs": 5000,
      "SendTimeoutMs": 10000,
      "ReceiveTimeoutMs": 10000,
      "SendBufferSize": 65536,
      "ReceiveBufferSize": 65536,
      "NoDelay": true,
      "KeepAlive": true,
      "MaxRetryAttempts": 3,
      "RetryIntervalMs": 1000
    },
    "Kcp": {
      "ConnectionTimeoutMs": 5000,
      "SendTimeoutMs": 10000,
      "ReceiveTimeoutMs": 10000,
      "MaxRetryAttempts": 5,
      "RetryIntervalMs": 500,
      "CustomProperties": {
        "NoDelay": true,
        "Interval": 10,
        "Resend": 2,
        "NoCongestionWindow": false,
        "SendWindowSize": 32,
        "ReceiveWindowSize": 32,
        "Mtu": 1400
      }
    },
    "Memory": {
      "ConnectionTimeoutMs": 1000,
      "SendTimeoutMs": 5000,
      "ReceiveTimeoutMs": 5000,
      "CustomProperties": {
        "BufferSize": 1048576,
        "EnableLatencySimulation": false,
        "SimulatedLatencyMs": 0
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "PulseRPC.Benchmark": "Debug",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "Console": {
      "IncludeScopes": false,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/benchmark-{Date}.log",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 7
    }
  },
  "Output": {
    "ResultsDirectory": "results",
    "Formats": ["json", "csv", "html"],
    "IncludeRawData": false,
    "CompressResults": true,
    "AutoOpenReport": false
  },
  "Display": {
    "EnableRealTimeDisplay": true,
    "RefreshIntervalMs": 500,
    "EnableColors": true,
    "EnableUnicodeChars": true,
    "FallbackToSimpleDisplay": true,
    "SimpleDisplayUpdateIntervalSeconds": 5,
    "ShowSystemResources": true,
    "ShowDetailedLatency": true
  },
  "Advanced": {
    "EnableCpuProfiling": false,
    "EnableMemoryProfiling": false,
    "EnableNetworkCapture": false,
    "GarbageCollectionMode": "Concurrent",
    "ThreadPoolSettings": {
      "MinWorkerThreads": null,
      "MaxWorkerThreads": null,
      "MinCompletionPortThreads": null,
      "MaxCompletionPortThreads": null
    }
  }
}
