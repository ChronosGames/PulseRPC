<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ShouldUnsetParentConfigurationAndPlatform>false</ShouldUnsetParentConfigurationAndPlatform>
    <AddSyntheticProjectReferencesForSolutionDependencies>false</AddSyntheticProjectReferencesForSolutionDependencies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\PulseRPC.Server\PulseRPC.Server.csproj"
                      SetConfiguration="Configuration=$(Configuration)"
                      AdditionalProperties="ShouldUnsetParentConfigurationAndPlatform=false" />
    <ProjectReference Include="..\..\..\src\PulseRPC.Server.SourceGenerator\PulseRPC.Server.SourceGenerator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      SetConfiguration="Configuration=$(Configuration)"
                      AdditionalProperties="ShouldUnsetParentConfigurationAndPlatform=false" />
    <ProjectReference Include="..\HelloRPC.Contracts\HelloRPC.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
  </ItemGroup>

</Project>
