<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Source Generator Settings -->
    <EnableSourceGenerators>true</EnableSourceGenerators>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)Generated</CompilerGeneratedFilesOutputPath>
    <!-- 启用临时对象MemoryPack生成器 -->
    <PulseRPC_EnableMemoryPackGenerator>true</PulseRPC_EnableMemoryPackGenerator>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\PulseRPC.Core\PulseRPC.Core.csproj" />
    <ProjectReference Include="..\..\..\src\PulseRPC.Client.SourceGenerator\PulseRPC.Client.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MemoryPack" />
    <!-- 移除对 MemoryPack.Generator 的依赖 -->
  </ItemGroup>

</Project>
