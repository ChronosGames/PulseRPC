{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "PulseRPC": "Information"
    }
  },
  "AllowedHosts": "*",
  "ServerIdentity": {
    "ServiceType": "BackendServer",
    "NodeId": 1,
    "NodeName": "BackendServer-Node1",
    "MaxCapacity": 50000
  },
  "Network": {
    "External": {
      "Enabled": false
    },
    "Internal": {
      "Enabled": true,
      "Host": "127.0.0.1",
      "Port": 10300,
      "Transports": [
        {
          "Name": "BackendServerInternalTcp",
          "Type": "Tcp",
          "Port": 10300,
          "IsDefault": true
        }
      ],
      "NodeId": 1,
      "MaxConnections": 5000
    }
  },
  "ServiceRegistration": {
    "ServiceId": "backend-server-1",
    "ServiceType": "BackendServer",
    "NodeId": 1,
    "NodeName": "BackendServer-Node1",
    "Host": "localhost",
    "TcpPort": 10300,
    "KcpPort": null,
    "MaxCapacity": 50000
  },
  "MongoDB": {
    "ConnectionString": "mongodb://admin:password123@localhost:27017",
    "SocialDatabase": "game_social",
    "GuildsDatabase": "game_guilds",
    "LeaderboardsDatabase": "game_leaderboards"
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceBasePath": "pulserpc",
    "HealthCheckInterval": 10,
    "HealthCheckTimeout": 3,
    "DeregisterCriticalServiceAfter": 30
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "Production",
    "Enabled": false,
    "SampleRate": 1.0,
    "TracesSampleRate": 0.1,
    "SendDefaultPii": false,
    "MaxBreadcrumbs": 100,
    "AttachStacktrace": true
  },
  "ClusterSecret": "your-cluster-secret-key-change-in-production",
  "JwtSecret": "your-jwt-secret-key-change-in-production"
}
