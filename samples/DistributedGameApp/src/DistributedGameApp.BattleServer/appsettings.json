{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "PulseRPC": "Information"
    }
  },
  "AllowedHosts": "*",
  "ServerIdentity": {
    "ServiceType": "BattleServer",
    "NodeId": 1,
    "NodeName": "BattleServer-Node1",
    "MaxCapacity": 10000
  },
  "Network": {
    "External": {
      "Enabled": true,
      "Host": "0.0.0.0",
      "Tcp": {
        "Port": 9080,
        "Enabled": true
      },
      "Kcp": {
        "Port": 9081,
        "Enabled": true
      },
      "Transports": [
        {
          "Name": "BattleServerTcp",
          "Type": "Tcp",
          "Port": 9080,
          "IsDefault": true
        },
        {
          "Name": "BattleServerKcp",
          "Type": "Kcp",
          "Port": 9081,
          "IsDefault": false
        }
      ],
      "NodeId": 1,
      "MaxConnections": 10000
    },
    "Internal": {
      "Enabled": true,
      "Host": "127.0.0.1",
      "Port": 10200,
      "Transports": [
        {
          "Name": "BattleServerInternalTcp",
          "Type": "Tcp",
          "Port": 10200,
          "IsDefault": true
        }
      ],
      "NodeId": 1,
      "MaxConnections": 1000
    }
  },
  "ServiceRegistration": {
    "ServiceId": "battle-server-1",
    "ServiceType": "BattleServer",
    "NodeId": 1,
    "NodeName": "BattleServer-Node1",
    "Host": "localhost",
    "TcpPort": 9080,
    "KcpPort": 9081,
    "MaxCapacity": 10000
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceBasePath": "pulserpc",
    "HealthCheckInterval": 10,
    "HealthCheckTimeout": 3,
    "DeregisterCriticalServiceAfter": 30
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "Production",
    "Enabled": false,
    "SampleRate": 1.0,
    "TracesSampleRate": 0.1,
    "SendDefaultPii": false,
    "MaxBreadcrumbs": 100,
    "AttachStacktrace": true
  },
  "ClusterSecret": "your-cluster-secret-key-change-in-production",
  "JwtSecret": "your-jwt-secret-key-change-in-production"
}
