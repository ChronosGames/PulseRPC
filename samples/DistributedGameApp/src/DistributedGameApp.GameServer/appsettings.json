{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "PulseRPC": "Information"
    }
  },
  "AllowedHosts": "*",
  "ServerIdentity": {
    "ServiceType": "GameServer",
    "NodeId": 1,
    "NodeName": "GameServer-Node1",
    "MaxCapacity": 5000
  },
  "Network": {
    "External": {
      "Enabled": true,
      "Host": "0.0.0.0",
      "Tcp": {
        "Port": 8080,
        "Enabled": true
      },
      "Kcp": {
        "Port": 8081,
        "Enabled": true
      },
      "Transports": [
        {
          "Name": "GameServerTcp",
          "Type": "Tcp",
          "Port": 8080,
          "IsDefault": true
        },
        {
          "Name": "GameServerKcp",
          "Type": "Kcp",
          "Port": 8081,
          "IsDefault": false
        }
      ],
      "NodeId": 1,
      "MaxConnections": 5000
    },
    "Internal": {
      "Enabled": true,
      "Host": "127.0.0.1",
      "Port": 10100,
      "Transports": [
        {
          "Name": "GameServerInternalTcp",
          "Type": "Tcp",
          "Port": 10100,
          "IsDefault": true
        }
      ],
      "NodeId": 1,
      "MaxConnections": 1000
    }
  },
  "ServiceRegistration": {
    "ServiceId": "game-server-1",
    "ServiceType": "GameServer",
    "NodeId": 1,
    "NodeName": "GameServer-Node1",
    "Host": "localhost",
    "TcpPort": 8080,
    "KcpPort": 8081,
    "MaxCapacity": 5000
  },
  "MongoDB": {
    "ConnectionString": "mongodb://admin:password123@localhost:27017",
    "AccountsDatabase": "game_accounts",
    "CharactersDatabase": "game_characters",
    "SocialDatabase": "game_social",
    "GuildsDatabase": "game_guilds",
    "BattlesDatabase": "game_battles",
    "LeaderboardsDatabase": "game_leaderboards"
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceBasePath": "pulserpc",
    "HealthCheckInterval": 10,
    "HealthCheckTimeout": 3,
    "DeregisterCriticalServiceAfter": 30
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "Production",
    "Enabled": false,
    "SampleRate": 1.0,
    "TracesSampleRate": 0.1,
    "SendDefaultPii": false,
    "MaxBreadcrumbs": 100,
    "AttachStacktrace": true
  },
  "ClusterSecret": "your-cluster-secret-key-change-in-production",
  "JwtSecret": "your-jwt-secret-key-change-in-production"
}
