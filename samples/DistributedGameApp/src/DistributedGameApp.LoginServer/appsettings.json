{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServerIdentity": {
    "ServiceType": "LoginServer",
    "NodeId": 1,
    "NodeName": "LoginServer-Node1",
    "MaxCapacity": 10000
  },
  "Network": {
    "External": {
      "Enabled": false
    },
    "Internal": {
      "Enabled": false
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Jwt": {
    "SecretKey": "DistributedGameApp_Secret_Key_2025_Must_Be_At_Least_32_Characters_Long",
    "Issuer": "DistributedGameApp.LoginServer",
    "Audience": "DistributedGameApp.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "MongoDB": {
    "ConnectionString": "mongodb://admin:password123@localhost:27017",
    "AccountsDatabase": "game_accounts",
    "CharactersDatabase": "game_characters",
    "SocialDatabase": "game_social",
    "GuildsDatabase": "game_guilds",
    "BattlesDatabase": "game_battles",
    "LeaderboardsDatabase": "game_leaderboards"
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceBasePath": "pulserpc",
    "HealthCheckInterval": 10,
    "HealthCheckTimeout": 3,
    "DeregisterCriticalServiceAfter": 30
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "Production",
    "Enabled": false,
    "SampleRate": 1.0,
    "TracesSampleRate": 0.1,
    "SendDefaultPii": false,
    "MaxBreadcrumbs": 100,
    "AttachStacktrace": true
  }
}
