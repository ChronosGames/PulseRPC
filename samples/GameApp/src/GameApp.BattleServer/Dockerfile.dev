# BattleServer Development Dockerfile
FROM mcr.microsoft.com/dotnet/runtime:9.0 AS base
WORKDIR /app
EXPOSE 8000 8001

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copy project files
COPY ["src/GameApp.BattleServer/GameApp.BattleServer.csproj", "src/GameApp.BattleServer/"]
COPY ["src/GameApp.Shared/GameApp.Shared.csproj", "src/GameApp.Shared/"]
COPY ["src/GameApp.Infrastructure/GameApp.Infrastructure.csproj", "src/GameApp.Infrastructure/"]
COPY ["Directory.Packages.props", ""]

# Restore dependencies
RUN dotnet restore "src/GameApp.BattleServer/GameApp.BattleServer.csproj"

# Copy source code
COPY . .

# Build application
WORKDIR "/src/GameApp.BattleServer"
RUN dotnet build "GameApp.BattleServer.csproj" -c Debug -o /app/build

FROM build AS publish
RUN dotnet publish "GameApp.BattleServer.csproj" -c Debug -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

ENTRYPOINT ["dotnet", "GameApp.BattleServer.dll"]
