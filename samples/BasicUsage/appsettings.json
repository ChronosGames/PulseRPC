{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "PulseRPC": "Debug"
    }
  },
  "PulseRPC": {
    "Client": {
      "ServiceDiscoveryOptions": {
        "RefreshInterval": "00:00:30",
        "CacheTimeout": "00:05:00",
        "EnableCaching": true,
        "EnableHealthCheck": true
      },
      "LoadBalancingOptions": {
        "Strategy": "RoundRobin",
        "EnableHealthCheck": true,
        "HealthCheckInterval": "00:00:30",
        "EnableStatistics": true
      }
    },
    "Server": {
      "ListenEndPoint": "0.0.0.0:8000",
      "ServiceRegistryOptions": {
        "ServiceName": "PulseRPC.Sample.BasicUsage",
        "ServiceVersion": "1.0.0",
        "EnableHealthCheck": true,
        "HealthCheckInterval": "00:00:30",
        "Tags": {
          "environment": "development",
          "version": "1.0.0",
          "region": "local",
          "datacenter": "dc1"
        },
        "Metadata": {
          "description": "PulseRPC基础使用示例服务",
          "owner": "PulseRPC Team",
          "contact": "support@pulserpc.com"
        }
      }
    }
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "Datacenter": "dc1",
    "Token": "",
    "EnableHealthCheck": true,
    "HealthCheckInterval": "00:00:10",
    "HealthCheckTimeout": "00:00:05",
    "DeregisterOnShutdown": true
  },
  "HealthCheck": {
    "DefaultTimeout": "00:00:05",
    "TcpCheckTimeout": "00:00:03",
    "HttpCheckTimeout": "00:00:05",
    "PingTimeout": "00:00:02",
    "RetryCount": 2,
    "RetryDelay": "00:00:00.500",
    "EnableConcurrentChecks": true,
    "MaxConcurrentChecks": 50
  },
  "Failover": {
    "FailureThreshold": 3,
    "RecoveryThreshold": 2,
    "FailedEndpointCheckInterval": "00:00:30",
    "CircuitBreakerOpenTime": "00:01:00",
    "HalfOpenTestRatio": 0.1,
    "EnableGracefulDegradation": true,
    "MinHealthyEndpoints": 1
  }
} 