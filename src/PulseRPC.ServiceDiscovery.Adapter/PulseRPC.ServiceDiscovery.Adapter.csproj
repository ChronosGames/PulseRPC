<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>PulseRPC.ServiceDiscovery.Adapter</PackageId>
    <Title>PulseRPC ServiceDiscovery Adapter</Title>
    <Description>Adapter for integrating PulseServiceDiscovery with PulseRPC framework</Description>
    <Authors>PulseRPC Team</Authors>
    <Company>PulseRPC</Company>
    <Product>PulseRPC</Product>
    <Copyright>Copyright © PulseRPC Team</Copyright>
    <PackageTags>pulserpc;servicediscovery;adapter;microservices;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/PulseRPC/PulseRPC</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PulseRPC.Client\PulseRPC.Client.csproj" />
    <ProjectReference Include="..\PulseRPC.Server\PulseRPC.Server.csproj" />
    <ProjectReference Include="..\PulseServiceDiscovery.Abstractions\PulseServiceDiscovery.Abstractions.csproj" />
    <ProjectReference Include="..\PulseServiceDiscovery.Client\PulseServiceDiscovery.Client.csproj" />
    <ProjectReference Include="..\PulseServiceDiscovery.Server\PulseServiceDiscovery.Server.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>

</Project>
