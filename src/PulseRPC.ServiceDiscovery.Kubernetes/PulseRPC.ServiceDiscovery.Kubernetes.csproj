<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>PulseRPC.ServiceDiscovery.Kubernetes</PackageId>
    <Title>PulseServiceDiscovery Kubernetes Plugin</Title>
    <Description>Kubernetes plugin for PulseServiceDiscovery framework</Description>
    <Authors>PulseRPC Team</Authors>
    <Company>PulseRPC</Company>
    <Product>PulseServiceDiscovery</Product>
    <Copyright>Copyright © PulseRPC Team</Copyright>
    <PackageTags>pulserpc;servicediscovery;kubernetes;k8s;microservices;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/PulseRPC/PulseRPC</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RootNamespace>PulseServiceDiscovery.Kubernetes</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="KubernetesClient" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PulseRPC.Cluster\PulseRPC.Cluster.csproj" />
  </ItemGroup>

</Project>
