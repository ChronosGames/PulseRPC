<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>PulseServiceDiscovery.Server</PackageId>
    <Description>服务端服务发现和注册实现</Description>
    <Authors>PulseRPC Team</Authors>
    <PackageTags>servicediscovery;server;registry;pulse;rpc</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PulseServiceDiscovery.Abstractions\PulseServiceDiscovery.Abstractions.csproj" />
    <ProjectReference Include="..\PulseServiceDiscovery.Client\PulseServiceDiscovery.Client.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
  </ItemGroup>

</Project>
