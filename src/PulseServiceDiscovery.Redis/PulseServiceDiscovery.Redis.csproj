<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>PulseServiceDiscovery.Redis</PackageId>
    <Title>PulseServiceDiscovery Redis Plugin</Title>
    <Description>Redis plugin for PulseServiceDiscovery framework</Description>
    <Authors>PulseRPC Team</Authors>
    <Company>PulseRPC</Company>
    <Product>PulseServiceDiscovery</Product>
    <Copyright>Copyright © PulseRPC Team</Copyright>
    <PackageTags>pulserpc;servicediscovery;redis;microservices;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/PulseRPC/PulseRPC</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PulseServiceDiscovery.Abstractions\PulseServiceDiscovery.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="StackExchange.Redis" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>
</Project>

